{
  "name": "protecao-gui",
  "version": "2.0.0",
  "description": "Proteção — Interface gráfica para instalação e configuração de segurança (Python + React + Electron)",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "NODE_ENV=development electron .",
    "dev": "concurrently -n VITE,ELECTRON -c blue,green \"npm run dev:vite\" \"sleep 3 && npm run dev:electron\"",
    "build": "vite build",
    "start": "npm run build && electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cobe": "^2.0.1",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
